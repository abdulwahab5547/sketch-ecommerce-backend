PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# MongoDB connection string. For Atlas this looks like:
#   mongodb+srv://user:pass@cluster.mongodb.net/sketch_ecommerce
# For local mongod:
#   mongodb://127.0.0.1:27017/sketch_ecommerce
MONGODB_URI=

# Default admin user — only used the first time the seed runs against an
# empty database. Change the password and re-seed against a fresh DB to
# rotate it. (Existing users in the DB are never overwritten by seed.)
ADMIN_EMAIL=admin@zaidikram.art
ADMIN_PASSWORD=admin1234

CORS_ORIGIN=http://localhost:5173

# --- Cloudinary (admin image uploads) ---------------------------------
# Fill these in from your Cloudinary dashboard. Uploads happen on the
# backend (admin only) so the API key/secret stay server-side.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: folder to upload product images into. Defaults to "sketch-ecommerce/products".
CLOUDINARY_FOLDER=sketch-ecommerce/products

# --- Email (order notifications via Gmail SMTP) -----------------------
# Use a Gmail "App Password" (NOT your normal password). Requires 2-Step
# Verification: https://myaccount.google.com/apppasswords
# When MAIL_USER/MAIL_PASS are unset, emails are skipped (logged, never fatal).
MAIL_USER=
MAIL_PASS=
# Friendly From header shown to customers. Defaults to MAIL_USER.
MAIL_FROM="Your Studio <you@gmail.com>"
# Where new-order alerts go. Defaults to MAIL_USER.
OWNER_EMAIL=
# Public site URL for "track your order" links in emails. Defaults to the
# first CORS_ORIGIN entry.
STORE_URL=http://localhost:5173
